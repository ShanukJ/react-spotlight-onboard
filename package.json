{
  "name": "react-spotlight-onboard",
  "version": "1.0.0",
  "description": "Zero-dependency React onboarding tour with SVG spotlight, smart tooltip placement, and keyboard navigation.",
  "keywords": [
    "react",
    "onboarding",
    "tour",
    "spotlight",
    "guide",
    "walkthrough",
    "tooltip",
    "overlay",
    "product-tour",
    "user-onboarding"
  ],
  "license": "MIT",
  "author": "ShanukJ",
  "repository": {
    "type": "git",
    "url": "https://github.com/shanukj/react-spotlight-onboard.git"
  },
  "bugs": {
    "url": "https://github.com/shanukj/react-spotlight-onboard/issues"
  },
  "homepage": "https://spotlight.shanukj.me",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --clean --watch",
    "lint": "eslint . --max-warnings 0",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.19.0",
    "tsup": "^8.3.6",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0"
  }
}
